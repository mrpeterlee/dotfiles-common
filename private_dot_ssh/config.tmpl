# Base SSH client config. Per-org host lists live in overlays under
# ~/.ssh/config.d/<org>-hosts.conf. The Include directive below pulls
# them in if present.

Include ~/.ssh/config.d/*.conf

# Cross-platform defaults.
Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
{{ if .isWindows -}}
    ForwardX11 no
{{ end -}}
