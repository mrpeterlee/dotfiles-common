{
  // User-level oh-my-opencode configuration
  // Cross-org defaults that apply everywhere
  "agents": {
    "explore": {
      "model": "anthropic/claude-haiku-4-5",
      "temperature": 0.5,
      "permission": { "edit": "deny", "bash": "ask", "webfetch": "allow" }
    }
  },
  "skills": {
    "sources": [
      { "path": "~/.config/opencode/skills", "recursive": true }
    ],
    "enable": ["git-master", "playwright"]
  },
  "disabled_skills": []
}
