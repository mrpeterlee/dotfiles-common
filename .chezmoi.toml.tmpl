{{- /* Prompt for machine-specific configuration */ -}}
{{- $email := promptStringOnce . "email" "Git email address" "your-email@example.com" -}}
{{- $name := promptStringOnce . "name" "Git user name" "Your Name" -}}
{{- $hostname := promptStringOnce . "hostname" "Machine hostname" (output "hostname" | trim) -}}
{{- $personal := promptBoolOnce . "personal" "Is this a personal machine" true -}}

{{- /* Detect platform characteristics */ -}}
{{- $osid := .chezmoi.os -}}
{{- $arch := .chezmoi.arch -}}
{{- $isWSL := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   if (stat "/proc/sys/fs/binfmt_misc/WSLInterop") -}}
{{-     $isWSL = true -}}
{{-   end -}}
{{- end -}}
{{- $isDarwin := eq .chezmoi.os "darwin" -}}
{{- $isLinux := eq .chezmoi.os "linux" -}}
{{- $isWindows := eq .chezmoi.os "windows" -}}

{{- /* Detect package manager */ -}}
{{- $pkgmgr := "apt" -}}
{{- if $isWindows -}}
{{-   $pkgmgr = "winget" -}}
{{- else if $isDarwin -}}
{{-   $pkgmgr = "brew" -}}
{{- else if lookPath "pacman" -}}
{{-   $pkgmgr = "pacman" -}}
{{- else if lookPath "dnf" -}}
{{-   $pkgmgr = "dnf" -}}
{{- end -}}

{{- /* Detect if 1Password CLI is available and signed in */ -}}
{{- $hasOp := false -}}
{{- $opSignedIn := false -}}
{{- if lookPath "op" -}}
{{-   $hasOp = true -}}
{{-   $opSignedIn = (output "op" "account" "list" "--format=json" | fromJson | len) | gt 0 -}}
{{- end -}}

# Root-level chezmoi configuration (must be before any sections)
sourceDir = {{ joinPath .chezmoi.homeDir ".files" | quote }}

[data]
    email = {{ $email | quote }}
    name = {{ $name | quote }}
    hostname = {{ $hostname | quote }}
    personal = {{ $personal }}

    osid = {{ $osid | quote }}
    arch = {{ $arch | quote }}
    isWSL = {{ $isWSL }}
    isDarwin = {{ $isDarwin }}
    isLinux = {{ $isLinux }}
    isWindows = {{ $isWindows }}

    pkgmgr = {{ $pkgmgr | quote }}
    hasOp = {{ $hasOp }}
    opSignedIn = {{ $opSignedIn }}

{{ if $isWindows -}}
[interpreters.ps1]
    command = "pwsh"
    args = ["-NoProfile", "-NoLogo"]
{{ else -}}
[edit]
    command = "nvim"

[diff]
    pager = "diff-so-fancy"

[merge]
    command = "nvim"
    args = ["-d", "{{ "{{" }} .Destination {{ "}}" }}", "{{ "{{" }} .Source {{ "}}" }}", "{{ "{{" }} .Target {{ "}}" }}"]
{{ end -}}

{{ if $hasOp -}}
[onepassword]
    command = "op"
    prompt = false
{{- end }}

[git]
    autoCommit = false
    autoPush = false
